<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberNest_Desktop"
        xmlns:System="clr-namespace:System;assembly=mscorlib" x:Class="CyberNest_Desktop.MainWindow"
        mc:Ignorable="d"
        Title="CyberNest - Adminfelület (bejelentkezés)" Height="800" Width="998" Background="Gray">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="34*" />
            <ColumnDefinition/>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="35*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0*" />
            <RowDefinition Height="68.82" />
            <RowDefinition Height="31.18"/>
            <RowDefinition Height="250" />
            <RowDefinition Height="100" />
            <RowDefinition Height="0*" />
        </Grid.RowDefinitions>
        <StackPanel x:Name="loginPage" Background="Gray"  Grid.Column="3" Grid.Row="3" Height="334" VerticalAlignment="Top" Visibility="Visible" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="50" />
                    <RowDefinition Height="50" />
                    <RowDefinition Height="50" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Felhasználónév:" Grid.Row="2" Margin="0,16,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" RenderTransformOrigin="1.106,0.861" FontSize="18"/>
                <TextBox x:Name="usernameTextBox" Grid.Row="2" Grid.Column="1" Margin="5,5,5,5" FontSize="25"/>
                <TextBlock Text="Jelszó:" Grid.Row="3" Grid.Column="0" Margin="5,15,5,0" VerticalAlignment="Top" FontSize="18" />
                <PasswordBox x:Name="passwordBox" Grid.Row="3" Grid.Column="1" Margin="5,3,5,3" FontSize="25"/>
                <Button x:Name="loginButton"  Content="Bejelentkezés" Grid.Row="4" Grid.ColumnSpan="2" Margin="5,59,5,-36" Click="loginButton_Click"/>
                <TextBlock x:Name="errorMessageTextBlock" Grid.Row="3" Grid.ColumnSpan="2" Margin="5" Foreground="Red" Visibility="Collapsed"/>
            </Grid>
        </StackPanel>
        <!-- Adminisztrációs vezérlőpult-->
        <StackPanel x:Name="homePage"  Background="LightGray" Grid.Row="1" Grid.RowSpan="5" Grid.ColumnSpan="6" Width="NaN" Margin="0,0,0,-334" >
            <Grid Height="57" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="TopMenu" Visibility="Visible">
                    <Grid Height="58" Background="#2D2D30" Width="1000">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto" MinWidth="136.12"/>
                        </Grid.ColumnDefinitions>
                        <!-- ITT VAN MÉG KIS HIBA - a felhasználók kezelése gomb eseménykezelője nem jeleníti meg a "FelhasznalokOldal" panelt. -->
                        <!-- 
                            SABLON #1:
                            <Button x:Name="" <- ide a név
                                Grid.Column="0" <- Oszlop sorszáma
                                Margin="10" <- Baloldali margó
                                Click=""> <- Click esemény kezelője
                                <StackPanel Orientation="Horizontal"> <- Ezt ne változtasd!
                                    <Image Source=""  Width="20" Height="20" Margin="0,0,8,0"/> <- Kép méretezése
                                    <TextBlock Text=""/> <- Gomb felirata
                                </StackPanel>
                            </Button>
                        
                            SABLON #2
                            <Button x:Name=""
                                Grid.Column="0"
                                Margin="10" 
                                Click=""> 
                                <StackPanel Orientation="Horizontal"> 
                                    <Image Source=""  Width="20" Height="20" Margin="0,0,8,0"/> 
                                    <TextBlock Text=""/>
                                </StackPanel>
                            </Button>
                        -->

                        <Button x:Name="felhasznaloKezeles"
                            Grid.Column="0"
                            Margin="10,10,10,10"
                            Click="felhasznaloKezeles_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/user.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Felhasználók Kezelése" Width="119"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="EszkozokButton" 
                                Grid.Column="1"
                                Margin="10,10,10,10"
                                Click="EszkozokButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/tools.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Eszközök kezelése" Height="18" Width="102"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="viewReportsButton"
                                Grid.Column="2"
                                Margin="10,10,379,10" 
                                Click="viewReportsButton_Click" Grid.ColumnSpan="2">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/report.png"  Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Jelentések Kezelése" Height="18" Width="105"/>
                            </StackPanel>
                        </Button>


                        <Button x:Name="settingsButton"
                                Grid.Column="3"
                                Margin="173,10,244,10" 
                                Click="settingsButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/settings.png"  Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Beállítások" Height="18" Width="66"/>

                            </StackPanel>
                        </Button>

                        <Button x:Name="logoutButton"
                                Grid.Column="4"
                                Margin="10,10,10,10" 
                                Click="logoutButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/logout.png"  Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Kijelentkezés" Height="18" Width="69"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
            <Grid x:Name="EszkozokGrid"  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="1368"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto" MinWidth="0"/>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="Auto" MinWidth="136.12"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="eszkozokoldal" Visibility="Visible" Background="Bisque" Orientation="Horizontal">

                    <!--ESZKÖZÖK KILISTÁZÁSA-->
                    <StackPanel x:Name="eszkozListazasPanel" Visibility="Hidden">
                        <Grid Height="auto" Width="auto">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="445*"/>
                                <ColumnDefinition Width="678*"/>
                            </Grid.ColumnDefinitions>
                            <ListView x:Name="EszkozListView" d:ItemsSource="{d:SampleData ItemCount=0}" Width="264" Margin="159,0,255,0" Grid.Column="1" >
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <Button x:Name="eszkozListaVissza" Content="Vissza" Margin="22,5,305,5" Click="eszkozListaVissza_Click"/>

                        </Grid>
                    </StackPanel>
                    <!-- ESZKÖZ HOZZÁADÁS -->
                    <StackPanel x:Name="eszkozHozzadasPanel"  Visibility="Hidden" >
                        <Grid Height="auto" Width="auto">
                            <Button x:Name="eszkozHozzaadasGomb" Content="Hozzáadás" Height="auto" Width="auto" Margin="234,90,476,0" Click="eszkozHozzaadasGomb_Click"/>
                            <TextBox x:Name="eszkozLeiras" Text="leiras" Margin="10,10,592,82"/>
                            <TextBox x:Name="eszkozCpu" Text="cpu" Margin="10,28,592,64"/>

                            <TextBox x:Name="eszkozRam" Text="ram" Margin="10,64,592,28"/>
                            <TextBox x:Name="eszkozHdd" Text="hdd" Margin="10,46,592,46"/>
                            <ComboBox x:Name="UzemeltetoID" Margin="234,12,469,76">
                                <ComboBoxItem Content="UzemeltetoID1" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                    <!-- ESZKÖZ TÖRLÉS -->
                    <StackPanel x:Name="eszkozTorlespanel" Visibility="Hidden">
                        <Grid Height="auto" Width="auto">
                            <ComboBox x:Name="IDs" Margin="340,90,335,0"/>
                            <Button x:Name="eszkozTorlesGomb" Content="Törlés" Height="auto" Width="auto" Margin="234,90,476,0" Click="eszkozTorlesGomb_Click"/>
                        </Grid>
                    </StackPanel>
                    <!-- ESZKÖZ MÓDOSÍTÁS -->
                    <StackPanel x:Name="eszkozModositasPanel" Visibility="Hidden">
                        <Grid Height="auto" Width="auto">
                            <ComboBox x:Name="EszkModIDs" Width="120" Margin="377,-187,303,277" />
                            <TextBox x:Name="eszkozModLeiras" Text="leiras" Margin="19,-204,583,297"/>
                            <TextBox x:Name="eszkozModCpu" Text="cpu" Margin="19,-185,583,277"/>

                            <TextBox x:Name="eszkozModRam" Text="ram" Margin="19,-145,583,237"/>
                            <TextBox x:Name="eszkozModHdd" Text="hdd" Margin="19,-165,583,257"/>
                            <Button x:Name="eszkozModositasGomb" Content="Módosítás" Height="auto" Width="auto" Margin="282,-187,428,277" Click="eszkozModositasGomb_Click"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>

                <!-- FELHASZNÁLÓK OLDAL -->
                <StackPanel x:Name="FelhasznalokOldal" Visibility="Hidden" Height="auto" Margin="0,0,368,0">
                    <StackPanel Margin="0,25,368,10" Height="741" Width="998" >
                        <StackPanel.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="BlueViolet" Offset="0.627"/>
                                <GradientStop Color="#FF158000"/>
                                <GradientStop Color="Aqua" Offset="0.964"/>
                            </LinearGradientBrush>
                        </StackPanel.Background>

                        <StackPanel x:Name="FelhasznalokHozzaadasPanel" Visibility="Visible" Height="131" >

                            <Grid Height="auto" Width="auto">

                                <Button x:Name="FelhasznaloHozzaadasGomb" Content="Hozzáadás" Height="auto" Width="auto" Margin="434,60,276,30" Click="FelhasznaloHozzaadasGomb_Click"/>
                                <TextBox x:Name="FelhasznaloNev" Text="Felhasznalonév" Margin="10,1,592,113" MouseDoubleClick="FelhasznaloNev_MouseDoubleClick"/>
                                <PasswordBox x:Name="FelhasznaloJelszo" Height="23" Margin="10,29,592,0" VerticalAlignment="Top"/>
                                <ComboBox x:Name="FelhasznaloAllapot" Margin="10,84,592,30" >
                                    <ComboBoxItem Content="Aktív" />
                                    <ComboBoxItem Content="Inaktív" />
                                </ComboBox>
                                <ComboBox x:Name="FelhasznaloJogosultsag" Margin="10,57,592,57">
                                    <ComboBoxItem Content="Admin" />
                                    <ComboBoxItem Content="User" />
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="FelhasznalokListazasPanel" Visibility="Hidden" Height="147" Width="371">

                            <Button x:Name="felhasznaloListaVissza" Content="Vissza" Click="felhasznaloListaVissza_Click" Width="111"/>

                            <ListView x:Name="FelhasznaloListView" d:ItemsSource="{d:SampleData ItemCount=0}" Height="146" Width="370" >
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                        </StackPanel>

                        <!--Felhasznalok hozzaadasa-->
                        <!-- Felhasznalok listazas-->
                    </StackPanel>
                    <!--Eszközök CRUD kész 2026.01.26 - Ezt a sablont kell követni a többi CRUD-nál is!-->

                    <StackPanel x:FieldModifier="private" x:Name="ManageUsersPage" Visibility="Hidden">
                        <Grid Height="100">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Column="1" Content="módosítás" HorizontalAlignment="Left" Margin="10,30,0,0" VerticalAlignment="Top" Width="72"/>
                            <Button Grid.Column="1" Content="törlés" Margin="10,0,2,70" RenderTransformOrigin="0.5,0.5"/>
                            <ListView x:Name="ManageUserList" Grid.Column="1" d:ItemsSource="{d:SampleData ItemCount=0}" Margin="279,0,-383,0" Grid.RowSpan="2">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel Visibility="Visible" Orientation="Horizontal" Background="DarkBlue" Margin="0,-56,2356,857">
                    <Grid>

                        <Button x:Name="eszkozHozzaadas" 
                                    Height="auto" 
                                    Width="148" 
                                    Click="eszkozHozzaadas_Click"
                                    Margin="369,54,0,0" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/Devices/Device_add.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Eszközök hozzáadása" Height="18" Width="113"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="eszkozTorles" 
                                    Height="auto" 
                                    Click="eszkozTorles_Click"
                                    Margin="540,54,1053,0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Device_Delete.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Eszközök törlése" Height="18" Width="95"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="eszkozModositas" 
                                    Height="auto" Width="auto" 
                                    Click="eszkozModositas_Click"
                                    Margin="188,54,1370,0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/Devices/Device_Modify.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Eszközök módosítása" Height="18" Width="112"/>
                            </StackPanel>
                        </Button>
                        <Button
                                x:Name="eszkozListazas" 
                                Height="auto" Width="auto" 
                                Click="eszkozListazas_Click" 
                                Margin="10,54,1551,0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Images/Devices/Device_List.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Eszközök kilistázása" Height="18" Width="107"/>
                            </StackPanel>
                        </Button>

                    </Grid>
                </StackPanel>












            </Grid>
        </StackPanel>
        <TextBlock x:Name="MainText" Visibility="Visible" Foreground="White" Grid.Column="4" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top" Height="57" Grid.Row="1" Width="190" FontFamily="Arial Black" FontSize="24" Grid.ColumnSpan="2" Margin="22,-2,0,0">
            <TextBlock.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FFE01111" Offset="1"/>
                    <GradientStop Color="#FF001BFF"/>
                </LinearGradientBrush>
            </TextBlock.Background><Run Language="hu-hu" Text="CyberNest - Adminfelület"/></TextBlock>
        <StackPanel x:Name="FelhasznalokTopMenu" Visibility="Hidden" Orientation="Horizontal" Grid.ColumnSpan="6" Margin="0,55,0,16" Grid.RowSpan="3" Background="DarkBlue">


            <Grid Width="880" Height="27">
                <Button x:Name="felhasznalokHozzaadas" 
                                Height="auto" Width="auto" 
                                Margin="0,3,706,4" 
                                Click="felhasznalokHozzaadas_Click" >
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Person_Add.png" Width="20" Height="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználók hozzáadása" Height="14" Width="138"/>
                    </StackPanel>
                </Button>
                <Button x:Name="felhasznalokTorles" 
                                    Height="auto" Width="auto" 
                                    Margin="185,3,554,4" 
                                    Click="felhasznalokTorles_Click" >
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/Users/Person_Delete.png" Width="20" Height="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználók törlése" Height="18" Width="112"/>
                    </StackPanel>
                </Button>
                <Button x:Name="felhasznalokModositas" 
                                    Height="auto" Width="auto"
                                    Margin="337,3,379,4" 
                                    Click="felhasznalokModositas_Click" >
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/Users/Person_Modify.png" Width="20" Height="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználók módosítása" Height="18" Width="138"/>
                    </StackPanel>
                </Button>
                <Button x:Name="felhasznalokListazas"
                                    Height="auto" Width="auto"
                                    Margin="512,3,212,4"  
                                    Click="felhasznalokListazas_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/Users/Person_List.png" Width="20" Height="20"/>
                        <TextBlock Text="Felhasználók kilistázása" Height="18" Width="128"/>
                    </StackPanel>
                </Button>

            </Grid>
        </StackPanel>





    </Grid>
</Window>
