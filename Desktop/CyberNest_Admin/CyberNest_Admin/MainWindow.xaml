<Window x:Class="CyberNest_Admin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberNest_Admin"
        mc:Ignorable="d"
        Title="CyberNest Admin felület" Height="450" Width="800">
    <Grid>
        <!--FIGYELEM! ÁLTALÁNOS TÁJÉKOZTATÓ ERRŐL AZ XAML FÁJLRÓL:
        1. Fontos panelek nevei és láthatósággal kapcsolatos beállításaik:
            - LoginPage: Ez a StackPanel tartalmazza a bejelentkezési űrlapot. Ez a panel kezdetben már látszik
            - SideBrand_loginPage: Ez a StackPanel tartalmazza a jobb oldali márkázási elemeket. 
            - MainContentPage: Ez a StackPanel tartalmazza a fő tartalmat, beleértve a menüt és egyéb adminisztrációs elemeket. Kezdetben rejtett, és csak akkor lesz látható, amikor a bejelentkezés sikeres volt.
        -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Background="#FF3426DE"
                    Grid.RowSpan="5" 
                    Grid.ColumnSpan="3"
                    Visibility="Hidden"/>


        <StackPanel x:Name="SideBrand_loginPage" 
                    Grid.Column="3"
                    Grid.RowSpan="5"
                    Visibility="Hidden">
            <StackPanel.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF153CDA"/>
                    <GradientStop Color="#FF1D64C5" Offset="1"/>

                    <GradientStop Color="#FF2AB5B2" Offset="0.506"/>
                </LinearGradientBrush>
            </StackPanel.Background>
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <TextBlock TextWrapping="Wrap" Foreground="White" Text="CyberNest - Admin felület" FontSize="20" Margin="0,213,0,-266" Grid.Row="2" FontWeight="Bold" TextTrimming="WordEllipsis" FontFamily="Corbel" HorizontalAlignment="Center" Width="132" FontStyle="Italic">
                    <TextBlock.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFF91700"/>
                            <GradientStop Color="#FFFF21F7" Offset="1"/>
                            <GradientStop Color="#FF0839FF" Offset="0.473"/>
                            <GradientStop Color="#FF81277E" Offset="0.159"/>
                        </LinearGradientBrush>
                    </TextBlock.Background>
                </TextBlock>

            </Grid>
        </StackPanel>
        <StackPanel x:Name="MainContentPage"
                    Grid.ColumnSpan="5"
                    Grid.RowSpan="5"
                    Visibility="Visible">
            <StackPanel.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFF8000"/>
                    <GradientStop Color="#FF2E0BAD" Offset="1"/>
                    <GradientStop Color="Red" Offset="0.477"/>
                </LinearGradientBrush>
            </StackPanel.Background>
            <!--Ez csak akkor lesz látható ha a bejelentkezés sikeres volt.-->
            <Menu x:Name="TopMainMenu"
                  Height="21" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                <MenuItem x:Name="FelhasznalokMenu"
                         Header="Felhasználók" 
                          FontSize="14">
                    <MenuItem x:Name="FelhasznalokListajaMenu" Header="Felhasználók listája" Click="FelhasznalokListajaMenu_Click"/>
                    <MenuItem x:Name="UjFelhasznaloMenu" Header="Új felhasználó" Click="UjFelhasznaloMenu_Click"/>
                    <MenuItem x:Name="FelhasznaloTorleseMenu" Header="Felhasználó törlése" Click="FelhasznaloTorleseMenu_Click"/>
                    <MenuItem x:Name="FelhasznaloModositasMenu" Header="Felhasználó módosítása" Click="FelhasznaloModositasMenu_Click"/>
                </MenuItem>
                <MenuItem x:Name="EszkozokMenu"
                          Header="Eszközök" 
                          FontSize="14">
                    <MenuItem x:Name="EszkozokListajaMenu" Header="Eszközök listája" Click="EszkozokListajaMenu_Click"/>
                    <MenuItem x:Name="UjEszkozMenu" Header="Új eszköz" Click="UjEszkozMenu_Click"/>
                    <MenuItem x:Name="EszkozTorleseMenu" Header="Eszköz törlése" Click="EszkozTorleseMenu_Click"/>
                    <MenuItem x:Name="EszkozModositasMenu" Header="Eszköz módosítása" Click="EszkozModositasMenu_Click"/>
                </MenuItem>
            </Menu>
            <Grid Height="412" Width="799" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Felhasznalok listázás -->
                <StackPanel x:Name="FelhasznaloListPanel"
                            Background="Gray"
                            Margin="0,66,0,10"
                            Grid.Column="1"
                            Grid.RowSpan="4"
                            Grid.ColumnSpan="2"
                            Visibility="Hidden">
                    <Button x:Name="FelhasznalokListBackBtn" Content="Vissza" Width="84" Click="FelhasznalokListBackBtn_Click"/>
                    <ListView x:Name="FelhasznalokListView">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Név" DisplayMemberBinding="{Binding Nev}" Width="150"/>
                                <GridViewColumn Header="E-mail" DisplayMemberBinding="{Binding Elerhetoseg}" Width="200"/>
                                <GridViewColumn Header="Szerepkör" DisplayMemberBinding="{Binding Role}" Width="100"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
                <!-- Új felhasználó létrehozása -->
                <StackPanel x:Name="UjFelhasznaloPanel"
                            Background="LightGray"
                            Margin="0,66,0,10"
                            Grid.Column="1"
                            Grid.RowSpan="4"
                            Grid.ColumnSpan="2"
                            Visibility="Hidden">
                    <Button x:Name="UjFelhasznaloBackBtn" Content="Vissza" Width="84"/>
                    <TextBlock Text="Név:" Margin="10"/>
                    <TextBox x:Name="UjFelhasznaloNev" Margin="10"/>
                    <TextBlock Text="E-mail:" Margin="10"/>
                    <TextBox x:Name="UjFelhasznaloEmail" Margin="10"/>
                    <TextBlock Text="Szerepkör:" Margin="10"/>
                    <ComboBox x:Name="UjFelhasznaloRole" Margin="10">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="User"/>
                    </ComboBox>
                    <Button x:Name="UjFelhasznaloSaveBtn" Content="Mentés" Width="84" Margin="10" Click="UjFelhasznaloSaveBtn_Click"/>
                </StackPanel>


                <!-- Eszkozok list -->
                <StackPanel x:Name="EszkozokListPanel"
                            Grid.Column="0"
                            Grid.RowSpan="3"
                            Grid.ColumnSpan="3"
                            HorizontalAlignment="Left"
                            Background="Gray" 
                            Margin="0,82,0,0" 
                            Width="590"
                            Visibility="Hidden">
                    <Button x:Name="EszkozokListBackBtn" Content="Vissza" Width="84" Click="EszkozokListBackBtn_Click"/>
                    <ListView x:Name="EszkozokListView" 
                              Height="146" 
                              ItemsSource="{Binding Eszkozok}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="20"/>
                                <GridViewColumn Header="leírás" DisplayMemberBinding="{Binding Leiras}" Width="100"/>
                                <GridViewColumn Header="CPU" DisplayMemberBinding="{Binding Cpu}" Width="100"/>
                                <GridViewColumn Header="RAM" DisplayMemberBinding="{Binding Ram}" Width="100"/>
                                <GridViewColumn Header="HDD" DisplayMemberBinding="{Binding Hdd}" Width="100"/>
                                <GridViewColumn Header="uzemelteto_nev" DisplayMemberBinding="{Binding UzemeltetoNev}" Width="180"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                </StackPanel>
                <!-- Új eszköz hozzáadása -->
                <StackPanel x:Name="ujEszkozPanel"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="3"
                            Background="Gray" Margin="0,82,0,0">
                    <Grid Height="165">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
    
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock HorizontalAlignment="Left" Margin="33,0,0,0" Grid.Row="1" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center"/>
                    </Grid>


                </StackPanel>
            </Grid>

        </StackPanel>
        <StackPanel x:Name="LoginPage"
                    Background="LightBlue"
                    Width="200"
                    RenderTransformOrigin="0.5,0.5"
                    HorizontalAlignment="Center"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Visibility="Hidden">

            <Grid Height="86" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="67*"/>
                    <ColumnDefinition Width="43*"/>
                    <ColumnDefinition Width="90*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock TextWrapping="Wrap" 
                                Text="Felhasználónév:"
                                Margin="0,6,0,7" />
                <TextBox x:Name="txtUser"
                            Text="TextBox" 
                            Grid.ColumnSpan="2" Margin="17,8,0,3" HorizontalAlignment="Left" Width="106" Grid.Column="1"/>
                <Button x:Name="Bejelentkezes"
                            Content="Bejelentkezés" 
                            Grid.Column="2" 
                            Grid.Row="1" Margin="1,28,0,5" Grid.RowSpan="2" Click="Bejelentkezes_Click"/>

                <TextBlock TextWrapping="Wrap" 
                               Text="Jelszó:" 
                               Margin="0,7,0,7" 
                               Grid.Row="1" />
                <PasswordBox x:Name="txtPass" Grid.Column="1" Grid.ColumnSpan="2" Margin="17,7,0,6" Grid.Row="1" HorizontalAlignment="Left" Width="106"/>
            </Grid>

        </StackPanel>
    </Grid>
</Window>
